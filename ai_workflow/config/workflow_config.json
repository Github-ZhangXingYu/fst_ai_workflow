{
  "_comment": "FST AI测试工作流配置文件 — 所有阈值、路径、循环限制",

  "thresholds": {
    "statement_coverage": 90,
    "branch_coverage": 80,
    "min_test_per_function": 1,
    "min_test_types": ["unit"]
  },

  "limits": {
    "test_fix_max_iterations": 4,
    "coverage_supplement_max_iterations": 2,
    "compile_timeout_seconds": 300,
    "test_timeout_seconds": 300,
    "benchmark_timeout_seconds": 600,
    "codegraph_timeout_seconds": 30,
    "max_impact_functions_per_batch": 10,
    "max_total_impact_functions": 50
  },

  "paths": {
    "service_dir": "service",
    "test_dir": "tests",
    "build_dir": "build",
    "product_dir": "product",
    "test_binary_dir": "product/bin/unittest",
    "state_dir": "ai_workflow/state",
    "report_dir": "ai_workflow/reports",
    "config_dir": "ai_workflow/config",
    "template_dir": "ai_workflow/config/templates"
  },

  "triggers": {
    "auto_trigger_enabled": true,
    "watch_extensions": [".cpp", ".h", ".hpp", ".cc", ".cxx", ".hxx"],
    "watch_paths": ["service/"]
  },

  "deepseek_optimization": {
    "max_context_functions": 5,
    "max_context_lines": 500,
    "structured_prompts": true,
    "validate_output_before_apply": true,
    "single_function_per_call": true,
    "prefer_small_batches": true
  },

  "coverage": {
    "enabled": true,
    "tool": "lcov",
    "exclude_patterns": [
      "/usr/include/*",
      "/usr/local/include/*",
      "*/googletest/*",
      "*/gtest/*",
      "*/gmock/*",
      "*/test/*",
      "*/tests/*",
      "*/build/*",
      "*/third_party/*",
      "*/3rdparty/*",
      "*/external/*"
    ]
  },

  "report": {
    "language": "zh-CN",
    "format": "markdown",
    "include_screenshots": false,
    "chapters": [
      "summary",
      "impact",
      "assessment",
      "test_results",
      "coverage",
      "traceability",
      "compile_fixes",
      "gaps"
    ]
  }
}
